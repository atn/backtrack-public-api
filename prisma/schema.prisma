generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int              @id @default(autoincrement())
  email                  String           @unique
  password               String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  pushToken              String?
  ebayId                 String?          @unique
  ebayAccessToken        String?
  ebayRefreshToken       String?
  ebayTokenExpiry        DateTime?
  ebayRefreshTokenExpiry DateTime?
  lastFeedRefresh        DateTime?
  feedPreferences        Json?
  behaviorProfile        Json?
  achievements           Json?
  sellingStats           Json?
  lastFeedInteraction    DateTime?
  feedEngagementScore    Float?
  googleAccounts         GoogleAccount[]
  oAuthStates            OAuthState[]
  processedEmails        ProcessedEmail[]
  receipts               Receipt[]
  receiptItems           ReceiptItem[]    @relation("UserReceiptItems")
}

model ProcessedEmail {
  id                String        @id @default(cuid())
  userId            Int
  googleAccountId   String
  googleEmailId     String        @unique
  sender            String?
  receivedAt        DateTime?
  processedAt       DateTime      @default(now())
  status            String
  subject           String?
  snippet           String?
  errorMessage      String?
  rawContent        String?
  extractedDataJson String?
  googleAccount     GoogleAccount @relation(fields: [googleAccountId], references: [id], onDelete: SetNull)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipt           Receipt?

  @@index([googleAccountId, googleEmailId])
  @@index([userId, status])
  @@index([status, processedAt])
}

model Receipt {
  id               String         @id @default(cuid())
  userId           Int
  processedEmailId String         @unique
  vendorName       String?
  transactionDate  DateTime?
  totalAmount      Float?
  currency         String         @default("USD")
  extractedAt      DateTime       @default(now())
  status           String
  processedEmail   ProcessedEmail @relation(fields: [processedEmailId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            ReceiptItem[]

  @@index([userId])
  @@index([processedEmailId])
}

model ReceiptItem {
  id                     String    @id @default(cuid())
  receiptId              String?
  userId                 Int
  itemName               String
  itemPrice              Float
  itemQuantity           Int
  sellScore              Int?
  status                 String    @default("pending")
  resaleValue            Float?
  imageUrl               String?
  resaleValueLastChecked DateTime?
  resaleValueHistory     Json?
  recommendedAction      String?
  lastFeedCandidateAt    DateTime?
  lastFeedReason         String?
  storeName              String?
  transactionDate        DateTime?
  swipedAt               DateTime?
  soldAt                 DateTime?
  feedInteractions       Json?
  userEngagement         Float?
  personalizedScore      Float?
  categoryTag            String?
  lastUserInteraction    DateTime?
  receipt                Receipt?  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  user                   User      @relation("UserReceiptItems", fields: [userId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([userId, status])
}

model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  userId    Int
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleAccount {
  id               String           @id @default(cuid())
  userId           Int
  googleId         String           @unique
  emailAddress     String           @unique
  accessToken      String
  refreshToken     String?
  tokenExpiry      DateTime?
  lastSyncStatus   String?
  lastSyncAt       DateTime?
  lastSyncProgress Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  processedEmails  ProcessedEmail[]

  @@index([userId])
  @@index([emailAddress])
}
